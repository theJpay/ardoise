{
    "name": "ardoise",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "description": "Local-first markdown notes, in your browser.",
    "author": "Jules Paris",
    "license": "MIT",
    "homepage": "https://ardoise.page",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/theJpay/ardoise.git"
    },
    "bugs": {
        "url": "https://github.com/theJpay/ardoise/issues"
    },
    "keywords": [
        "markdown",
        "notes",
        "local-first",
        "react",
        "typescript"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "release:pr": "gh pr create --base main --head beta --title \"Release v$npm_package_version\" --body \"$(git log main..beta --pretty=format:'- %s' --no-merges)\"",
        "release:sync-beta": "git checkout beta && git fetch origin && git merge origin/main --no-edit && git push",
        "release:tag": "gh release create \"v$npm_package_version\" --target main --generate-notes --title \"v$npm_package_version\""
    },
    "dependencies": {
        "@floating-ui/react": "^0.27.19",
        "@fontsource/ibm-plex-mono": "^5.2.7",
        "@fontsource/ibm-plex-sans": "^5.2.8",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/react-query": "^5.96.2",
        "dexie": "^4.4.2",
        "fflate": "^0.8.2",
        "hast-util-to-html": "^9.0.5",
        "lowlight": "^3.3.0",
        "lucide-react": "^0.577.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router": "^7.13.2",
        "rehype-sanitize": "^6.0.0",
        "rehype-stringify": "^10.0.1",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.1.2",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.1.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^24.12.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "autoprefixer": "^10.4.27",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4.2.2",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^8.0.1",
        "vite-plugin-svgr": "^5.0.0"
    }
}
